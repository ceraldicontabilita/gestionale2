# Ceraldi ERP .gitignore

# IDE
.idea/
.vscode/

# Dependencies
node_modules/
.pnp.js
.yarn/*
!.yarn/patches
!.yarn/plugins

# Testing
/coverage

# Production builds
/build
dist/

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# System files
.DS_Store
*.pem

# Python
__pycache__/
*.pyc
venv/
.venv/

# Archive files
**/*.zip
**/*.tar.gz
*.pack

# Build caches
.cache/
frontend/node_modules/.cache/

# Sensitive files (NOT .env — needed for deployment)
*token.json*
*credentials.json*
# (rimossi blocchi .env ripetuti — i file .env DEVONO stare nel repo per deployment Emergent)
-e 
