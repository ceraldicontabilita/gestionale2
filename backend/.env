MONGO_URL="mongodb://localhost:27017"
MONGODB_ATLAS_URI="mongodb://localhost:27017"
DB_NAME="azienda_erp"
CORS_ORIGINS="*"

# App Settings
APP_NAME="Azienda in Cloud ERP"
APP_VERSION="1.0.0"
ENVIRONMENT="development"
DEBUG="true"
ALLOW_CREDENTIALS="true"

# Secret Key (JWT)
SECRET_KEY="your-super-secret-key-change-in-production-min-32-chars-long"
JWT_ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES="43200"

# Email Settings (optional - for email integrations)
IMAP_HOST=""
IMAP_USER=""
IMAP_PASSWORD=""
IMAP_PORT="993"

# API Keys (optional)
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
GOOGLE_API_KEY=""

# Google OAuth (optional)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI=""

# InvoiceTronic (optional)
INVOICETRONIC_API_KEY=""
INVOICETRONIC_API_SECRET=""

# PagoPA (optional)
PAGOPA_API_KEY=""
PAGOPA_API_SECRET=""

# File Upload
MAX_UPLOAD_SIZE_MB="50"
UPLOAD_DIR="/app/app/uploads"
STATIC_DIR="/app/app/static"

# Rate Limiting
RATE_LIMIT_PER_MINUTE="200"

# Feature Flags
AUTH_DISABLED="true"
ENABLE_SCHEDULER="true"
ENABLE_EMAIL_MONITOR="true"
